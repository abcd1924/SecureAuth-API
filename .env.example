# SecureAuthAPI - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_secure_auth
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate a secure secret key (minimum 256 bits / 32 characters)
# You can generate one using: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_minimum_256_bits_long_replace_this_with_secure_random_string

# Access token expiration in milliseconds
# Default: 900000 ms = 15 minutes
JWT_EXPIRATION_MS=900000

# Refresh token expiration in milliseconds
# Default: 604800000 ms = 7 days
JWT_REFRESH_EXPIRATION_MS=604800000